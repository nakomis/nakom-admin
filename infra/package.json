{
  "name": "nakom-admin-infra",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "synth-sandbox": "NPM_ENVIRONMENT=sandbox cdk synth --profile nakom.is-sandbox --all",
    "synth-prod": "NPM_ENVIRONMENT=prod cdk synth --profile nakom.is-admin --all",
    "deploy-sandbox": "NPM_ENVIRONMENT=sandbox cdk deploy --profile nakom.is-sandbox --all --require-approval never",
    "deploy-prod": "NPM_ENVIRONMENT=prod cdk deploy --profile nakom.is-admin --all --require-approval never",
    "destroy-sandbox": "NPM_ENVIRONMENT=sandbox cdk destroy --profile nakom.is-sandbox --all",
    "ci-synth-sandbox": "NPM_ENVIRONMENT=sandbox cdk synth --all --output cdk-synth.out",
    "ci-deploy-sandbox": "NPM_ENVIRONMENT=sandbox cdk deploy --all --require-approval never --output cdk-deploy.out",
    "ci-deploy-prod": "NPM_ENVIRONMENT=prod cdk deploy --all --require-approval never --output cdk-deploy.out"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.998.0",
    "@aws-sdk/client-cloudfront": "^3.998.0",
    "@aws-sdk/client-dynamodb": "^3.998.0",
    "@aws-sdk/client-lambda": "^3.998.0",
    "@aws-sdk/client-rds": "^3.998.0",
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/client-ssm": "^3.998.0",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.0.0",
    "pg": "^8.19.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.16.0",
    "aws-cdk": "^2.180.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.0"
  }
}
